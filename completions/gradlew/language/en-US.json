{
  "meta": {
    "url": "https://docs.gradle.org/current/userguide/command_line_interface.html",
    "description": [
      "Gradle Wrapper - Build automation tool wrapper script."
    ]
  },
  "root": [
    {
      "name": "assemble",
      "tip": [
        "Assembles outputs of project without running tests."
      ]
    },
    {
      "name": "bootJar",
      "tip": [
        "Creates an executable jar for Spring Boot."
      ]
    },
    {
      "name": "bootRun",
      "tip": [
        "Runs the Spring Boot application."
      ]
    },
    {
      "name": "build",
      "tip": [
        "Builds the project, runs all checks."
      ]
    },
    {
      "name": "check",
      "tip": [
        "Runs all checks including tests and static analysis."
      ]
    },
    {
      "name": "clean",
      "tip": [
        "Deletes the build directory."
      ]
    },
    {
      "name": "compileJava",
      "tip": [
        "Compiles Java source files."
      ]
    },
    {
      "name": "compileTestJava",
      "tip": [
        "Compiles Java test source files."
      ]
    },
    {
      "name": "dependencies",
      "tip": [
        "Displays all dependencies of the project."
      ]
    },
    {
      "name": "dependencyInsight",
      "tip": [
        "Displays insight into a specific dependency."
      ]
    },
    {
      "name": "help",
      "tip": [
        "Displays help for Gradle."
      ]
    },
    {
      "name": "jar",
      "tip": [
        "Creates a JAR file."
      ]
    },
    {
      "name": "projects",
      "tip": [
        "Displays subprojects of the project."
      ]
    },
    {
      "name": "properties",
      "tip": [
        "Displays properties of the project."
      ]
    },
    {
      "name": "publish",
      "tip": [
        "Publishes all publications."
      ]
    },
    {
      "name": "publishToMavenLocal",
      "tip": [
        "Publishes to local Maven repository."
      ]
    },
    {
      "name": "tasks",
      "tip": [
        "Displays all available tasks."
      ]
    },
    {
      "name": "tasks --all",
      "tip": [
        "Displays all tasks including hidden ones."
      ]
    },
    {
      "name": "test",
      "tip": [
        "Runs the unit tests."
      ]
    },
    {
      "name": "war",
      "tip": [
        "Creates a WAR file."
      ]
    },
    {
      "name": "wrapper",
      "tip": [
        "Generates Gradle wrapper files."
      ]
    }
  ],
  "option": [
    {
      "name": "--build-file",
      "alias": [
        "-b"
      ],
      "tip": [
        "U: --build-file, -b <file>",
        "Specifies the build file."
      ],
      "next": 0
    },
    {
      "name": "--gradle-user-home",
      "tip": [
        "U: --gradle-user-home <dir>",
        "Specifies the Gradle user home directory."
      ],
      "next": 0
    },
    {
      "name": "--project-cache-dir",
      "tip": [
        "U: --project-cache-dir <dir>",
        "Specifies the project cache directory."
      ],
      "next": 0
    },
    {
      "name": "--project-dir",
      "tip": [
        "U: --project-dir <dir>",
        "Specifies the project directory."
      ],
      "next": 0
    },
    {
      "name": "--settings-file",
      "alias": [
        "-c"
      ],
      "tip": [
        "U: --settings-file, -c <file>",
        "Specifies the settings file."
      ],
      "next": 0
    }
  ],
  "common_option": [
    {
      "name": "--build-cache",
      "tip": [
        "Enables the Gradle build cache."
      ]
    },
    {
      "name": "--configure-on-demand",
      "tip": [
        "Configure only relevant projects."
      ]
    },
    {
      "name": "--continuous",
      "alias": [
        "-t"
      ],
      "tip": [
        "U: --continuous, -t",
        "Continuously builds when changes are detected."
      ]
    },
    {
      "name": "--daemon",
      "tip": [
        "Uses the Gradle daemon to run the build."
      ]
    },
    {
      "name": "--debug",
      "alias": [
        "-d"
      ],
      "tip": [
        "U: --debug, -d",
        "Set log level to debug."
      ]
    },
    {
      "name": "--dry-run",
      "alias": [
        "-m"
      ],
      "tip": [
        "U: --dry-run, -m",
        "Run without executing actions."
      ]
    },
    {
      "name": "--full-stacktrace",
      "tip": [
        "Print out the full stacktrace for exceptions."
      ]
    },
    {
      "name": "--help",
      "alias": [
        "-h",
        "-?"
      ],
      "tip": [
        "U: --help, -h, -?",
