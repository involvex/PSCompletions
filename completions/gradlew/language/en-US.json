      "name": "--no-build-cache",
      "tip": [
        "Disables the Gradle build cache."
      ]
    },
    {
      "name": "--no-configure-on-demand",
      "tip": [
        "Configure all projects."
      ]
    },
    {
      "name": "--no-daemon",
      "tip": [
        "Does not use the Gradle daemon to run the build."
      ]
    },
    {
      "name": "--no-parallel",
      "tip": [
        "Do not build projects in parallel."
      ]
    },
    {
      "name": "--offline",
      "tip": [
        "Build without accessing network."
      ]
    },
    {
      "name": "--parallel",
      "tip": [
        "Build projects in parallel."
      ]
    },
    {
      "name": "--profile",
      "tip": [
        "Profile build execution time."
      ]
    },
    {
      "name": "--quiet",
      "alias": [
        "-q"
      ],
      "tip": [
        "U: --quiet, -q",
        "Log errors only."
      ]
    },
    {
      "name": "--refresh-dependencies",
      "tip": [
        "Refresh the state of dependencies."
      ]
    },
    {
      "name": "--rerun",
      "tip": [
        "Specifies tasks to re-run."
      ],
      "next": 0
    },
    {
      "name": "--rerun-tasks",
      "tip": [
        "Forces all tasks to be re-run."
      ]
    },
    {
      "name": "--scan",
      "tip": [
        "Creates a build scan."
      ]
    },
    {
      "name": "--stacktrace",
      "tip": [
        "Print out the stacktrace for exceptions."
      ]
    },
    {
      "name": "--version",
      "alias": [
        "-v"
      ],
      "tip": [
        "U: --version, -v",
        "Prints version info."
      ]
    },
    {
      "name": "--warning-mode",
      "tip": [
        "U: --warning-mode <mode>",
        "Specify warning mode: all, summary, none."
      ],
      "next": [
        {
          "name": "all"
        },
        {
          "name": "none"
        },
        {
          "name": "summary"
        }
      ]
    }
  ]
}
