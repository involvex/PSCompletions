{
  "meta": {
    "url": "https:/docs.gradle.org/current/userguide/command_line_interface.html",
    "description": [
      "Gradle Wrapper - 构建自动化工具包装脚本。"
    ]
  },
  "root": [
    {
      "name": "assemble",
      "tip": [
        "组装项目输出，不运行测试。"
      ]
    },
    {
      "name": "bootJar",
      "tip": [
        "为 Spring Boot 创建可执行 jar。"
      ]
    },
    {
      "name": "bootRun",
      "tip": [
        "运行 Spring Boot 应用程序。"
      ]
    },
    {
      "name": "build",
      "tip": [
        "构建项目，运行所有检查。"
      ]
    },
    {
      "name": "check",
      "tip": [
        "运行所有检查，包括测试和静态分析。"
      ]
    },
    {
      "name": "clean",
      "tip": [
        "删除构建目录。"
      ]
    },
    {
      "name": "compileJava",
      "tip": [
        "编译 Java 源文件。"
      ]
    },
    {
      "name": "compileTestJava",
      "tip": [
        "编译 Java 测试源文件。"
      ]
    },
    {
      "name": "dependencies",
      "tip": [
        "显示项目的所有依赖项。"
      ]
    },
    {
      "name": "dependencyInsight",
      "tip": [
        "显示特定依赖项的详细信息。"
      ]
    },
    {
      "name": "help",
      "tip": [
        "显示 Gradle 帮助信息。"
      ]
    },
    {
      "name": "jar",
      "tip": [
        "创建 JAR 文件。"
      ]
    },
    {
      "name": "projects",
      "tip": [
        "显示项目的子项目。"
      ]
    },
    {
      "name": "properties",
      "tip": [
        "显示项目的属性。"
      ]
    },
    {
      "name": "publish",
      "tip": [
        "发布所有发布物。"
      ]
    },
    {
      "name": "publishToMavenLocal",
      "tip": [
        "发布到本地 Maven 仓库。"
      ]
    },
    {
      "name": "tasks",
      "tip": [
        "显示所有可用任务。"
      ]
    },
    {
      "name": "tasks --all",
      "tip": [
        "显示所有任务，包括隐藏任务。"
      ]
    },
    {
      "name": "test",
      "tip": [
        "运行单元测试。"
      ]
    },
    {
      "name": "war",
      "tip": [
        "创建 WAR 文件。"
      ]
    },
    {
      "name": "wrapper",
      "tip": [
        "生成 Gradle wrapper 文件。"
      ]
    }
  ],
  "option": [
    {
      "name": "--build-file",
      "alias": [
        "-b"
      ],
      "tip": [
        "U: --build-file, -b <file>",
        "指定构建文件。"
      ]
    },
    {
      "name": "--gradle-user-home",
      "tip": [
        "U: --gradle-user-home <dir>",
        "指定 Gradle 用户主目录。"
      ]
    },
    {
      "name": "--project-cache-dir",
      "tip": [
        "U: --project-cache-dir <dir>",
        "指定项目缓存目录。"
      ]
    },
    {
      "name": "--project-dir",
      "tip": [
        "U: --project-dir <dir>",
        "指定项目目录。"
      ]
    },
    {
      "name": "--settings-file",
      "alias": [
        "-c"
      ],
      "tip": [
        "U: --settings-file, -c <file>",
        "指定设置文件。"
      ]
    }
  ],
  "common_option": [
    {
      "name": "--build-cache",
      "tip": [
        "启用 Gradle 构建缓存。"
      ]
    },
    {
      "name": "--configure-on-demand",
      "tip": [
        "仅配置相关项目。"
      ]
    },
    {
      "name": "--continuous",
      "alias": [
        "-t"
      ],
      "tip": [
