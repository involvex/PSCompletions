        "显示帮助信息。"
      ]
    },
    {
      "name": "--info",
      "alias": [
        "-i"
      ],
      "tip": [
        "U: --info, -i",
        "设置日志级别为 info。"
      ]
    },
    {
      "name": "--no-build-cache",
      "tip": [
        "禁用 Gradle 构建缓存。"
      ]
    },
    {
      "name": "--no-configure-on-demand",
      "tip": [
        "配置所有项目。"
      ]
    },
    {
      "name": "--no-daemon",
      "tip": [
        "不使用 Gradle 守护进程运行构建。"
      ]
    },
    {
      "name": "--no-parallel",
      "tip": [
        "不并行构建项目。"
      ]
    },
    {
      "name": "--offline",
      "tip": [
